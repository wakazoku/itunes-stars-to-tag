# mirror_changed.py 用の設定例。
# このファイルを .env としてコピーし、自分の環境に合わせて値を編集してください。
# (.env はリポジトリにはコミットされません)

# iTunes 側 (タグ書き込みの対象) の音楽フォルダのルート
STAR_RATE_SYNC_SRC_ROOT=C:\Users\YOUR_NAME\Music\iTunes\iTunes Media\Music

# MusicBee 側 (コピー先) の音楽フォルダのルート
STAR_RATE_SYNC_DST_ROOT=C:\Users\YOUR_NAME\Music\MusicBee\Music
